<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_main_root"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:gravity="center">

    <Button
        android:id="@+id/btnNetworkSetting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Network Setting"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_restart"
        android:layout_width="558dp"
        android:layout_height="268dp"
        android:layout_marginStart="24dp"
        android:text="Restart"
        android:textSize="96sp"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="29dp" />

    <RadioGroup
        android:id="@+id/radioGroup_Language"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@+id/btn_restart"
        tools:layout_editor_absoluteX="83dp">

        <RadioButton
            android:id="@+id/radioButton_Mandarin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mandarin"
            android:textSize="96sp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radioButton_English"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="English"
            android:textSize="96sp" />
    </RadioGroup>

</androidx.constraintlayout.widget.ConstraintLayout>
